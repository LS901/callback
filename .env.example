# Copy to .env.local and fill in with your Supabase project's values
# (Project Settings -> API in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — never prefix with NEXT_PUBLIC_, must never reach the browser.
# Get this from console.anthropic.com -> Settings -> API Keys.
ANTHROPIC_API_KEY=

# Comma-separated list of emails allowed to sign in/up. Leave unset to open
# sign-up to anyone (e.g. for a public launch). See src/lib/auth-allowlist.ts.
ALLOWED_EMAILS=
